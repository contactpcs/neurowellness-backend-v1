# ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so

# Virtual environments
venv/
.venv/
env/
.env/
ENV/

# Packaging
dist/
build/
*.egg-info/
*.egg
wheels/
sdist/
MANIFEST

