node_modules/
dist/
.vite/
.cache/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Lock files (keep only one — remove the others)
# If using npm: keep package-lock.json, gitignore yarn.lock and pnpm-lock.yaml
yarn.lock
pnpm-lock.yaml

