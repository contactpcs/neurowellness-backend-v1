                { "value": 1, "label": "Always", "points": 1 }
            ]
        },
        {
            "id": "MSQ_12",
            "number": 12,
            "question": "How often have you felt fed up or frustrated?",
            "type": "likert",
            "required": true,
            "subscale": "emotional",
            "options": [
                { "value": 6, "label": "Never", "points": 6 },
                { "value": 5, "label": "Rarely", "points": 5 },
                { "value": 4, "label": "Sometimes", "points": 4 },
                { "value": 3, "label": "Pretty Often", "points": 3 },
                { "value": 2, "label": "Almost Always", "points": 2 },
