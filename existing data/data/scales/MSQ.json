                { "value": 2, "label": "Almost Always", "points": 2 },
                { "value": 1, "label": "Always", "points": 1 }
            ]
        },
        {
            "id": "MSQ_9",
            "number": 9,
            "question": "How often have you needed the help of other people in handling routine tasks such as everyday household chores, doing necessary business, shopping, or caring for others when you had a migraine attack?",
            "type": "likert",
            "required": true,
            "subscale": "role-preventive",
            "options": [
                { "value": 6, "label": "Never", "points": 6 },
                { "value": 5, "label": "Rarely", "points": 5 },
                { "value": 4, "label": "Sometimes", "points": 4 },
                { "value": 3, "label": "Pretty Often", "points": 3 },
                { "value": 2, "label": "Almost Always", "points": 2 },
                { "value": 1, "label": "Always", "points": 1 }
            ]
        },
        {
            "id": "MSQ_10",
            "number": 10,
            "question": "How often have you avoided social or family activities to treat your migraine attacks?",
            "type": "likert",
            "required": true,
            "subscale": "role-preventive",
            "options": [
                { "value": 6, "label": "Never", "points": 6 },
                { "value": 5, "label": "Rarely", "points": 5 },
                { "value": 4, "label": "Sometimes", "points": 4 },
