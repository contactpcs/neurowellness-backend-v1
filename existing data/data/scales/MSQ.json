                { "value": 3, "label": "Pretty Often", "points": 3 },
                { "value": 2, "label": "Almost Always", "points": 2 },
                { "value": 1, "label": "Always", "points": 1 }
            ]
        },
        {
            "id": "MSQ_6",
            "number": 6,
            "question": "How often have you had to cancel or delay work or social activities because you were exhausted?",
            "type": "likert",
            "required": true,
            "subscale": "role-restrictive",
            "options": [
                { "value": 6, "label": "Never", "points": 6 },
                { "value": 5, "label": "Rarely", "points": 5 },
                { "value": 4, "label": "Sometimes", "points": 4 },
                { "value": 3, "label": "Pretty Often", "points": 3 },
                { "value": 2, "label": "Almost Always", "points": 2 },
                { "value": 1, "label": "Always", "points": 1 }
            ]
        },
        {
            "id": "MSQ_7",
            "number": 7,
            "question": "How often have migraines left you with limited energy levels?",
            "type": "likert",
            "required": true,
            "subscale": "role-restrictive",
            "options": [
                { "value": 6, "label": "Never", "points": 6 },
                { "value": 5, "label": "Rarely", "points": 5 },
                { "value": 4, "label": "Sometimes", "points": 4 },
                { "value": 3, "label": "Pretty Often", "points": 3 },
