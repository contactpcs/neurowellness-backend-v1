            "number": 13,
            "question": "How often have you felt like you were a burden on others?",
            "type": "likert",
            "required": true,
            "subscale": "emotional",
            "options": [
                { "value": 6, "label": "Never", "points": 6 },
                { "value": 5, "label": "Rarely", "points": 5 },
                { "value": 4, "label": "Sometimes", "points": 4 },
                { "value": 3, "label": "Pretty Often", "points": 3 },
                { "value": 2, "label": "Almost Always", "points": 2 },
                { "value": 1, "label": "Always", "points": 1 }
            ]
        },
        {
            "id": "MSQ_14",
            "number": 14,
            "question": "How often have you been afraid of letting others down?",
            "type": "likert",
            "required": true,
            "subscale": "emotional",
            "options": [
                { "value": 6, "label": "Never", "points": 6 },
                { "value": 5, "label": "Rarely", "points": 5 },
                { "value": 4, "label": "Sometimes", "points": 4 },
                { "value": 3, "label": "Pretty Often", "points": 3 },
                { "value": 2, "label": "Almost Always", "points": 2 },
