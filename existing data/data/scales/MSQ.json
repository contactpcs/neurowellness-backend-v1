{
    "id": "MSQ",
    "name": "Migraine Specific Quality of Life Questionnaire",
    "shortName": "MSQ v2.1",
    "version": "2.1",
    "description": "A 14-item instrument that measures the impact of migraine on quality of life across three domains: Role Function-Restrictive (how migraines limit daily activities), Role Function-Preventive (how migraines prevent daily activities), and Emotional Function (emotional impact of migraines).",
    "category": "headache",
    "recallPeriod": "Over the past 4 weeks",
    "instructions": "While answering the following questions, please think about all migraine attacks you may have had in the past 4 weeks. For each question, select the response that best describes your experience.",
    "estimatedTime": "5-10 minutes",
    "scoringType": "msq-transformed",
    "maxScore": 100,
    "totalItems": 14,
    "administrationType": "self-report",

    "questions": [
        {
            "id": "MSQ_1",
            "number": 1,
            "question": "How often have migraines interfered with how well you dealt with family, friends and others who are close to you?",
            "type": "likert",
            "required": true,
            "subscale": "role-restrictive",
            "options": [
                { "value": 6, "label": "Never", "points": 6 },
                { "value": 5, "label": "Rarely", "points": 5 },
                { "value": 4, "label": "Sometimes", "points": 4 },
                { "value": 3, "label": "Pretty Often", "points": 3 },
                { "value": 2, "label": "Almost Always", "points": 2 },
                { "value": 1, "label": "Always", "points": 1 }
            ]
        },
        {
            "id": "MSQ_2",
            "number": 2,
            "question": "How often have migraines interrupted with your leisure time activities such as reading or exercising?",
            "type": "likert",
            "required": true,
            "subscale": "role-restrictive",
            "options": [
                { "value": 6, "label": "Never", "points": 6 },
                { "value": 5, "label": "Rarely", "points": 5 },
                { "value": 4, "label": "Sometimes", "points": 4 },
                { "value": 3, "label": "Pretty Often", "points": 3 },
                { "value": 2, "label": "Almost Always", "points": 2 },
                { "value": 1, "label": "Always", "points": 1 }
            ]
        },
        {
            "id": "MSQ_3",
            "number": 3,
            "question": "How often have you had difficulty in performing work or other daily activities?",
            "type": "likert",
            "required": true,
            "subscale": "role-restrictive",
            "options": [
                { "value": 6, "label": "Never", "points": 6 },
                { "value": 5, "label": "Rarely", "points": 5 },
                { "value": 4, "label": "Sometimes", "points": 4 },
                { "value": 3, "label": "Pretty Often", "points": 3 },
                { "value": 2, "label": "Almost Always", "points": 2 },
                { "value": 1, "label": "Always", "points": 1 }
            ]
        },
        {
            "id": "MSQ_4",
            "number": 4,
            "question": "How often have migraines kept you from getting as much accomplished as you normally do at work or at home?",
            "type": "likert",
            "required": true,
            "subscale": "role-restrictive",
            "options": [
                { "value": 6, "label": "Never", "points": 6 },
                { "value": 5, "label": "Rarely", "points": 5 },
                { "value": 4, "label": "Sometimes", "points": 4 },
                { "value": 3, "label": "Pretty Often", "points": 3 },
                { "value": 2, "label": "Almost Always", "points": 2 },
                { "value": 1, "label": "Always", "points": 1 }
            ]
        },
        {
            "id": "MSQ_5",
            "number": 5,
            "question": "How often have migraines limited your ability to work or do other activities as carefully as you usually do them?",
            "type": "likert",
            "required": true,
            "subscale": "role-restrictive",
            "options": [
                { "value": 6, "label": "Never", "points": 6 },
                { "value": 5, "label": "Rarely", "points": 5 },
