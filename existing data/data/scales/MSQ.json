    ],

    "subscales": [
        {
            "id": "role-restrictive",
            "name": "Role Function-Restrictive (RR)",
            "items": ["MSQ_1", "MSQ_2", "MSQ_3", "MSQ_4", "MSQ_5", "MSQ_6", "MSQ_7"],
            "rawScoreRange": "7-42",
            "transformedRange": "0-100",
            "formula": "(Raw Score - 7) × 100 / 35",
            "description": "Measures how migraines limit or restrict daily activities (7 items)"
        },
        {
            "id": "role-preventive",
            "name": "Role Function-Preventive (RP)",
            "items": ["MSQ_8", "MSQ_9", "MSQ_10", "MSQ_11"],
            "rawScoreRange": "4-24",
            "transformedRange": "0-100",
            "formula": "(Raw Score - 4) × 100 / 20",
            "description": "Measures how migraines prevent daily activities (4 items)"
        },
        {
            "id": "emotional",
            "name": "Emotional Function (EF)",
            "items": ["MSQ_12", "MSQ_13", "MSQ_14"],
            "rawScoreRange": "3-18",
            "transformedRange": "0-100",
            "formula": "(Raw Score - 3) × 100 / 15",
            "description": "Measures the emotional impact of migraines (3 items)"
        }
    ],

    "severityBands": [
        {
            "id": "severe-impact",
            "label": "Severe Impact",
            "min": 0,
            "max": 30,
            "color": "#dc2626",
            "description": "Migraines have a severe impact on quality of life."
        },
        {
            "id": "moderate-impact",
            "label": "Moderate Impact",
            "min": 31,
            "max": 50,
            "color": "#f97316",
            "description": "Migraines have a moderate impact on quality of life."
        },
        {
            "id": "mild-impact",
            "label": "Mild Impact",
            "min": 51,
            "max": 70,
            "color": "#eab308",
            "description": "Migraines have a mild impact on quality of life."
        },
        {
            "id": "minimal-impact",
            "label": "Minimal/No Impact",
            "min": 71,
            "max": 100,
            "color": "#22c55e",
            "description": "Migraines have minimal to no impact on quality of life."
        }
    ],

    "interpretation": {
        "scoringMethod": "Each subscale is scored separately. Raw scores are transformed to 0-100 scale. Higher transformed scores indicate better quality of life (less migraine impact).",
        "transformationFormulas": {
            "RR": "(Sum of items 1-7 minus 7) × 100 / 35",
            "RP": "(Sum of items 8-11 minus 4) × 100 / 20",
            "EF": "(Sum of items 12-14 minus 3) × 100 / 15"
        },
        "scoreInterpretation": "0 = maximum migraine impact, 100 = no migraine impact on that domain",
        "minimallyImportantDifference": "A change of 5 points on any subscale is considered clinically meaningful."
    },

    "references": [
        {
            "citation": "Martin BC, Pathak DS, Sharfman MI, et al. Validity and reliability of the migraine-specific quality of life questionnaire (MSQ Version 2.1). Headache. 2000;40(3):204-215.",
            "doi": "10.1046/j.1526-4610.2000.00030.x"
        },
        {
            "citation": "Jhingran P, Osterhaus JT, Miller DW, Cady RK, Davis LA. Development and validation of the Migraine-Specific Quality of Life Questionnaire. Headache. 1998;38(4):295-302."
        }
    ],

