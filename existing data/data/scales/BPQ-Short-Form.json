    "severityBands": [
        {
            "id": "occasional",
            "label": "Occasional Activation",
            "min": 20,
            "max": 42,
            "color": "#22c55e",
            "description": "Your autonomic stress response system activates only occasionally. This is within normal range."
        },
        {
            "id": "frequent",
            "label": "Frequent Activation",
            "min": 43,
            "max": 100,
            "color": "#f97316",
            "description": "Your autonomic stress response system may be active often. This may be normal if this is a time of high stress for you."
        }
    ],

    "interpretation": {
        "scoringMethod": "Add up values for all 20 questions. Total score range: 20-100.",
        "cutoffScore": 42,
        "cutoffPercentile": "80th percentile",
        "clinicalNotes": "The autonomic nervous system coordinates how the human brain and body work together to react to challenges in everyday life. Sometimes autonomic reactions may happen without your awareness, though you may feel the effects in specific parts of your body. At certain times in their life, these body reactions may be sensitive and easily triggered. This score provides a measure of how often your body's autonomic stress response is activated.",
        "interpretationGuidelines": {
            "20-42": "Autonomic stress response system activates only occasionally (80th percentile or lower).",
            "43-100": "Autonomic stress response system may be active often. May be normal during times of high stress."
        }
    },

