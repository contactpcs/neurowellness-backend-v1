{
    "id": "PFS-16",
    "name": "Parkinson's Disease Fatigue Scale",
    "shortName": "PFS-16",
    "version": "1.0",
    "description": "A 16-item scale specifically designed to assess fatigue and its impact in patients with Parkinson's disease. Measures both the presence and severity of fatigue experienced over the past two weeks.",
    "category": "fatigue",
    "recallPeriod": "Over the past two weeks",
    "instructions": "Printed below are a series of statements about fatigue and the impact that it can have. How well do the statements describe your own feelings and experiences over the past two weeks? Read each item and decide how much you agree or disagree with it. Tick only one box for each item and try not to miss any out.",
    "estimatedTime": "5-10 minutes",
    "scoringType": "pfs-dual",
    "maxScore": 80,
    "maxScoreBinary": 16,
    "totalItems": 16,
    "administrationType": "self-report",

