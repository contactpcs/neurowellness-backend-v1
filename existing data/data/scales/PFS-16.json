    "scoringMethods": [
        {
            "id": "method1",
            "name": "Full Likert Scoring",
            "description": "Sum of all item scores using 1-5 Likert values",
            "range": "16-80",
            "higherMeaning": "Greater fatigue severity"
        },
        {
            "id": "method2",
            "name": "Binary Scoring",
            "description": "Strongly disagree/Disagree/Neutral = 0, Agree/Strongly agree = 1",
            "range": "0-16",
            "cutoff": "≥8 indicates presence of significant fatigue",
            "higherMeaning": "More fatigue symptoms endorsed"
        }
    ],

    "severityBands": [
        {
            "id": "no-significant-fatigue",
            "label": "No Significant Fatigue",
            "min": 0,
            "max": 7,
            "color": "#22c55e",
            "description": "Binary score <8: No significant fatigue present.",
            "scoringMethod": "binary"
        },
        {
            "id": "significant-fatigue",
            "label": "Significant Fatigue",
            "min": 8,
            "max": 16,
            "color": "#dc2626",
            "description": "Binary score ≥8: Significant fatigue is present.",
            "scoringMethod": "binary"
        }
    ],

    "interpretation": {
        "scoringMethod1": {
            "method": "Sum all 16 items using Likert values (1-5). Range: 16-80.",
            "interpretation": "Higher scores indicate more severe fatigue."
        },
        "scoringMethod2": {
            "method": "Binary scoring: Strongly disagree/Disagree/Neutral = 0, Agree/Strongly agree = 1. Range: 0-16.",
            "cutoff": "A score of ≥8 indicates the presence of significant fatigue.",
            "interpretation": "Used for identifying clinically significant fatigue in Parkinson's disease."
        },
        "clinicalUse": "Specifically designed for Parkinson's disease patients. Can be used to monitor fatigue over time and evaluate treatment response."
    },

    "references": [
        {
            "citation": "Brown RG, Dittner A, Findley L, Wessely SC. The Parkinson fatigue scale. Parkinsonism Relat Disord. 2005;11(1):49-55.",
