{
    "id": "FSS",
    "name": "Fatigue Severity Scale",
    "shortName": "FSS",
    "version": "1.0",
    "description": "A 9-item self-report questionnaire that measures the severity of fatigue and its effect on a person's activities and lifestyle. Widely used in neurological conditions including multiple sclerosis, lupus, and chronic fatigue syndrome.",
    "category": "fatigue",
    "recallPeriod": "During the past week",
    "instructions": "Read each statement and select a number from 1 to 7, depending on how appropriate the statement applies to you over the preceding week. A low value (1) indicates strong disagreement, a high value (7) indicates strong agreement.",
    "estimatedTime": "3-5 minutes",
    "scoringType": "mean",
    "maxScore": 7,
    "minScore": 1,
    "totalItems": 9,
    "administrationType": "self-report",

    "questions": [
        {
            "id": "FSS_1",
            "number": 1,
            "question": "My motivation is lower when I am fatigued.",
            "type": "likert",
            "required": true,
            "options": [
                { "value": 1, "label": "1 - Strongly disagree", "points": 1 },
                { "value": 2, "label": "2", "points": 2 },
                { "value": 3, "label": "3", "points": 3 },
                { "value": 4, "label": "4 - Neutral", "points": 4 },
                { "value": 5, "label": "5", "points": 5 },
                { "value": 6, "label": "6", "points": 6 },
                { "value": 7, "label": "7 - Strongly agree", "points": 7 }
            ]
        },
