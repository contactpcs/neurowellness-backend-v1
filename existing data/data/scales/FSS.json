    "severityBands": [
        {
            "id": "no-fatigue",
            "label": "No Significant Fatigue",
            "range": { "min": 1.0, "max": 2.9 },
            "color": "#22c55e",
            "description": "No clinically significant fatigue."
        },
        {
            "id": "mild",
            "label": "Mild Fatigue",
            "range": { "min": 3.0, "max": 3.9 },
            "color": "#84cc16",
            "description": "Borderline fatigue, may warrant monitoring."
        },
        {
            "id": "moderate",
            "label": "Moderate Fatigue",
            "range": { "min": 4.0, "max": 4.9 },
            "color": "#eab308",
            "description": "Clinically significant fatigue present."
        },
        {
            "id": "severe",
            "label": "Severe Fatigue",
            "range": { "min": 5.0, "max": 7.0 },
            "color": "#dc2626",
            "description": "Severe fatigue significantly impacting daily functioning."
        }
    ],

    "interpretation": {
        "scoringMethod": "Calculate the mean of all 9 responses (sum of scores ÷ 9). Score range: 1-7.",
        "clinicalCutoff": "A mean score ≥4 indicates clinically significant fatigue.",
        "populationNorms": "Healthy adults typically score 2-3. Patients with chronic conditions often score 4-6.",
        "clinicalUse": "Widely used in multiple sclerosis, systemic lupus erythematosus, chronic fatigue syndrome, Parkinson's disease, and other conditions associated with fatigue.",
        "minimumClinicallyImportantDifference": "A change of 0.5-1.0 points in mean score is generally considered clinically meaningful."
    },

    "references": [
        {
            "citation": "Krupp LB, LaRocca NG, Muir-Nash J, Steinberg AD. The fatigue severity scale. Application to patients with multiple sclerosis and systemic lupus erythematosus. Arch Neurol. 1989;46(10):1121-1123.",
