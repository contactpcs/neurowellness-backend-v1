    "interpretation": {
        "scoringMethod": "Sum all 31 item scores (0-4 each) for a total score ranging from 0 to 124. Higher scores indicate greater symptom severity and functional impairment.",
        "clinicalCutoffs": {
            "minimal": "0-15: Minimal or no PANS symptoms",
            "mild": "16-40: Mild symptoms with slight interference",
            "moderate": "41-70: Moderate symptoms with definite interference",
            "severe": "71-100: Severe symptoms with substantial interference",
            "extreme": "101-124: Extreme symptoms, incapacitating"
        },
        "criticalItems": "Item 11 (Suicidal ideation/behavior) should be reviewed carefully regardless of total score. Any endorsement requires clinical follow-up.",
        "supplementalInfo": "Hours spent on obsessions and compulsions provide additional clinical context but are not included in the total score."
    },

