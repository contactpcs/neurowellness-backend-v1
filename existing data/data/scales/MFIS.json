{
    "id": "MFIS",
    "name": "Modified Fatigue Impact Scale",
    "shortName": "MFIS",
    "version": "1.0",
    "description": "A 21-item scale that assesses the effects of fatigue on physical, cognitive, and psychosocial functioning. Originally developed for multiple sclerosis but applicable to other conditions causing fatigue.",
    "category": "fatigue",
    "recallPeriod": "Over the past 4 weeks",
    "instructions": "Read each statement carefully and circle the one number that best indicates how often fatigue has affected you in this way during the past 4 weeks. Please answer every question. If you are not sure which answer to select, choose the one answer that comes closest to describing you.",
    "estimatedTime": "5-10 minutes",
    "scoringType": "sum",
    "maxScore": 84,
    "totalItems": 21,
    "administrationType": "self-report",

