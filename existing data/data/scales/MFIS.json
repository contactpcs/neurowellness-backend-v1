            "physical": "Items 4+6+7+10+13+14+17+20+21 (range 0-36)",
            "cognitive": "Items 1+2+3+5+11+12+15+16+18+19 (range 0-40)",
            "psychosocial": "Items 8+9 (range 0-8)"
        },
