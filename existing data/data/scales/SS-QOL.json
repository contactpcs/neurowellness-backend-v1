{
    "id": "SS-QOL",
    "name": "Stroke Specific Quality of Life Scale",
    "shortName": "SS-QOL",
    "version": "1.0",
    "description": "A patient-reported outcome measure designed to assess health-related quality of life specific to stroke survivors. Covers 12 domains including energy, family roles, language, mobility, mood, personality, self-care, social roles, thinking, upper extremity function, vision, and work/productivity.",
    "category": "quality-of-life",
    "recallPeriod": "Past week",
    "instructions": "Please answer each question based on how you have been doing in the past week. Score each item on a 5-point scale where higher scores indicate better functioning.",
    "estimatedTime": "10-15 minutes",
    "scoringType": "sum-subscales",
    "maxScore": 245,
    "minScore": 49,
    "totalItems": 49,
    "administrationType": "self-report",

    "responseScales": {
        "help": {
            "description": "Amount of help needed",
            "options": [
                { "value": 1, "label": "Total help", "points": 1 },
                { "value": 2, "label": "A lot of help", "points": 2 },
                { "value": 3, "label": "Some help", "points": 3 },
                { "value": 4, "label": "A little help", "points": 4 },
                { "value": 5, "label": "No help needed", "points": 5 }
            ]
        },
        "trouble": {
            "description": "Amount of trouble experienced",
            "options": [
                { "value": 1, "label": "Couldn't do it at all", "points": 1 },
                { "value": 2, "label": "A lot of trouble", "points": 2 },
                { "value": 3, "label": "Some trouble", "points": 3 },
                { "value": 4, "label": "A little trouble", "points": 4 },
                { "value": 5, "label": "No trouble at all", "points": 5 }
            ]
        },
        "agreement": {
            "description": "Level of agreement (reverse scored - disagreement = better)",
            "options": [
                { "value": 1, "label": "Strongly agree", "points": 1 },
                { "value": 2, "label": "Moderately agree", "points": 2 },
                { "value": 3, "label": "Neither agree nor disagree", "points": 3 },
                { "value": 4, "label": "Moderately disagree", "points": 4 },
                { "value": 5, "label": "Strongly disagree", "points": 5 }
            ]
        }
    },

