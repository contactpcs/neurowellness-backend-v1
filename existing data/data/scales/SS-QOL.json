    "interpretation": {
        "scoringMethod": "Sum all item scores. Higher scores indicate better quality of life. Domain scores can be calculated by summing items within each subscale.",
        "totalScoreRange": "49-245 (higher = better QOL)",
        "domainScoring": "Each domain is scored separately to identify specific areas of difficulty.",
        "responseFormats": "Three response formats are used: (1) Help needed (Self Care), (2) Trouble experienced (Language, Mobility, Upper Extremity, Vision, Work), (3) Agreement with negative statements (Energy, Family Roles, Mood, Personality, Social Roles, Thinking).",
        "clinicalUse": "Used to assess stroke-specific quality of life and identify domains requiring intervention. Can track recovery progress over time.",
        "note": "If patient cannot walk, score Mobility items 2-3 as 1 and proceed to item 4."
    },

