{
    "id": "MRC",
    "name": "MRC Scale for Muscle Strength",
    "shortName": "MRC",
    "version": "1.0",
    "description": "The Medical Research Council (MRC) scale is a standardized clinical assessment for grading muscle strength. Each muscle group is graded 0-5, with assessments performed bilaterally for upper and lower limbs.",
    "category": "motor-function",
    "recallPeriod": "Current examination",
    "instructions": "Grade each muscle group from 0 to 5 based on the strength observed during examination. MRC grade for each muscle must be given in full numbers (e.g., 4+ or 4.5 = 4, 4- = 3, 5- = 4).",
    "estimatedTime": "10-15 minutes",
    "scoringType": "sum",
    "maxScore": 60,
    "totalItems": 12,
    "administrationType": "clinician-rated",

    "gradeDefinitions": {
        "5": "Normal strength",
        "4": "Movement against gravity and resistance",
        "3": "Movement against gravity over (almost) the full range",
        "2": "Movement of the limb but not against gravity",
        "1": "Visible contraction without movement of the limb (not existent for hip flexion)",
        "0": "No visible contraction"
    },

