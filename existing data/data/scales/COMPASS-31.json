{
    "id": "COMPASS-31",
    "name": "Composite Autonomic Symptom Score-31",
    "shortName": "COMPASS-31",
    "description": "A 31-item self-report questionnaire assessing autonomic symptoms across 6 domains: orthostatic intolerance, vasomotor, secretomotor, gastrointestinal, bladder, and pupillomotor function",
    "version": "1.0",
    "recallPeriod": "Past year (unless otherwise specified)",
    "scoringType": "weighted-domain-sum",
    "maxScore": 100,
    
    "instructions": "Please answer all questions as accurately as possible based on your experiences over the past year. Some questions have skip patterns - follow the instructions provided.",
    
    "domains": [
        {
            "id": "orthostatic_intolerance",
            "name": "Orthostatic Intolerance",
            "description": "Symptoms related to standing up, including dizziness, lightheadedness, and fainting",
            "questionIndices": [0, 1, 2, 3],
            "maxRawScore": 10,
            "multiplier": 4,
            "maxWeightedScore": 40
