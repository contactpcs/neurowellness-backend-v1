    "scoringAlgorithm": {
        "method": "weighted-domain-sum",
        "steps": [
            "1. Calculate raw score for each domain by summing points from all items in that domain",
            "2. Multiply each domain raw score by its multiplier to get weighted domain score",
            "3. Sum all weighted domain scores to get total COMPASS-31 score"
        ],
        "domainCalculations": {
            "orthostatic_intolerance": "Sum of items 1-4 × 4",
            "vasomotor": "Sum of items 5-7 × 0.8333",
            "secretomotor": "Sum of items 8-11 × 2.1428571",
            "gastrointestinal": "Sum of items 12-23 × 0.8928571",
            "bladder": "Sum of items 24-26 × 1.111",
            "pupillomotor": "Sum of items 27-31 × 0.333"
        },
        "totalScore": "Sum of all 6 weighted domain scores"
    },
    
    "severityBands": [
        {
            "min": 0,
            "max": 15,
            "level": "minimal",
            "label": "Minimal Autonomic Dysfunction",
            "description": "Little to no evidence of autonomic dysfunction"
        },
        {
            "min": 16,
            "max": 30,
            "level": "mild",
            "label": "Mild Autonomic Dysfunction",
            "description": "Mild autonomic symptoms that may warrant monitoring"
        },
        {
            "min": 31,
            "max": 50,
            "level": "moderate",
            "label": "Moderate Autonomic Dysfunction",
            "description": "Moderate autonomic dysfunction; clinical evaluation recommended"
        },
        {
            "min": 51,
            "max": 100,
            "level": "severe",
            "label": "Severe Autonomic Dysfunction",
            "description": "Significant autonomic dysfunction; comprehensive autonomic testing recommended"
        }
    ],
    
    "riskRules": [
        {
            "domain": "orthostatic_intolerance",
            "operator": ">=",
            "threshold": 20,
            "severity": "moderate",
            "message": "High orthostatic intolerance score suggests significant postural symptoms; consider tilt table testing"
        },
        {
            "domain": "gastrointestinal",
            "operator": ">=",
            "threshold": 15,
            "severity": "moderate",
            "message": "Elevated GI domain score suggests gastroparesis or intestinal dysmotility; consider gastric emptying study"
        },
        {
            "domain": "bladder",
            "operator": ">=",
            "threshold": 7,
            "severity": "moderate",
            "message": "Elevated bladder domain score suggests neurogenic bladder dysfunction; consider urodynamic testing"
        },
        {
            "type": "total_score",
            "operator": ">=",
            "threshold": 50,
            "severity": "high",
            "message": "Total COMPASS-31 score ≥50 indicates significant autonomic dysfunction; comprehensive autonomic function testing recommended"
        }
    ],
    
    "interpretation": {
        "clinicalNotes": "COMPASS-31 is a validated self-assessment questionnaire for autonomic symptoms, derived from the original 169-item Autonomic Symptom Profile (ASP) and 84-item COMPASS. It provides both a total autonomic symptom score and domain-specific scores to characterize the pattern of autonomic dysfunction.",
        "domainInterpretation": {
            "orthostatic_intolerance": "Symptoms of dizziness, lightheadedness, or cognitive difficulty upon standing. High scores may indicate orthostatic hypotension, POTS, or other forms of orthostatic intolerance.",
            "vasomotor": "Skin color changes suggesting vascular dysregulation. May indicate Raynaud's phenomenon or other vasomotor abnormalities.",
            "secretomotor": "Abnormalities in sweating, lacrimation, and salivation. May indicate sudomotor dysfunction.",
            "gastrointestinal": "Symptoms of gastroparesis, intestinal dysmotility, or autonomic-related GI dysfunction.",
            "bladder": "Urinary symptoms including incontinence, retention, or voiding difficulties suggesting autonomic bladder dysfunction.",
            "pupillomotor": "Light sensitivity and focusing difficulties suggesting pupillary or accommodation abnormalities."
        },
        "clinicalApplications": [
            "Screening for autonomic neuropathy in diabetes",
            "Assessment of dysautonomia in Parkinson's disease",
            "Evaluation of small fiber neuropathy",
            "Monitoring autonomic symptoms in POTS and other autonomic disorders",
            "Research outcome measure for autonomic disorders"
        ],
        "actions": {
            "minimal": "No specific intervention indicated. Monitor as clinically appropriate.",
            "mild": "Clinical monitoring recommended. Consider targeted evaluation if specific domain is elevated.",
            "moderate": "Autonomic function testing recommended. Consider referral to autonomic specialist.",
            "severe": "Comprehensive autonomic evaluation strongly recommended. Referral to autonomic specialist indicated."
        },
        "limitationsAndConsiderations": [
            "Self-report measure subject to recall bias",
            "Symptoms may overlap with non-autonomic conditions",
            "Not diagnostic; positive screen should be followed by objective autonomic testing",
            "Domain scores help localize dysfunction but require confirmation with specific tests"
        ],
        "references": [
            "Sletten DM, Suarez GA, Low PA, Mandrekar J, Singer W. COMPASS 31: a refined and abbreviated Composite Autonomic Symptom Score. Mayo Clin Proc. 2012;87(12):1196-1201.",
            "Suarez GA, Opfer-Gehrking TL, Offord KP, Atkinson EJ, O'Brien PC, Low PA. The Autonomic Symptom Profile: a new instrument to assess autonomic symptoms. Neurology. 1999;52(3):523-528."
        ]
    }
}
