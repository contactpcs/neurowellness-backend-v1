    "recallPeriod": "Over the past 6 months",
    "instructions": "Please answer the questions below, rating yourself on each of the criteria. Place an X in the box that best describes how you have felt and conducted yourself over the past 6 months.",
    "estimatedTime": "5 minutes",
    "scoringType": "asrs-screening",
    "maxScore": 72,
    "totalItems": 18,

