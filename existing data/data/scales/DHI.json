    "severityBands": [
        {
            "id": "no-handicap",
            "label": "No Handicap",
            "min": 0,
            "max": 10,
            "color": "#22c55e",
            "description": "No significant dizziness-related handicap."
        },
        {
            "id": "mild",
            "label": "Mild Handicap",
            "min": 11,
            "max": 34,
            "color": "#eab308",
            "description": "Mild dizziness-related handicap; balance specialist referral may be warranted."
        },
        {
            "id": "moderate",
            "label": "Moderate Handicap",
            "min": 35,
            "max": 52,
            "color": "#f97316",
            "description": "Moderate dizziness-related handicap affecting daily activities."
        },
        {
            "id": "severe",
            "label": "Severe Handicap",
            "min": 53,
            "max": 100,
            "color": "#ef4444",
            "description": "Severe dizziness-related handicap with significant functional impairment."
        }
    ],

    "interpretation": {
        "scoringMethod": "Sum all items. No=0, Sometimes=2, Yes=4. Range: 0-100.",
        "referralThreshold": "Scores greater than 10 points should be referred to balance specialists for further evaluation.",
        "subscaleScoring": "Physical (7 items, max 28), Emotional (9 items, max 36), Functional (9 items, max 36)",
        "clinicalNotes": "The DHI provides both a total score and subscale scores to help identify the nature of the patient's dizziness-related difficulties."
    },

