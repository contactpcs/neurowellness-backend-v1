            "type": "likert",
            "required": true,
            "options": [
                { "value": 0, "label": "No", "points": 0 },
                { "value": 2, "label": "Sometimes", "points": 2 },
                { "value": 4, "label": "Yes", "points": 4 }
            ]
        },
