{
    "id": "DHI",
    "name": "Dizziness Handicap Inventory",
    "shortName": "DHI",
    "version": "1.0",
    "description": "A self-assessment questionnaire designed to evaluate the self-perceived handicapping effects of dizziness on daily life, incorporating functional, physical, and emotional impacts.",
    "category": "vestibular",
    "recallPeriod": "During the last month",
    "instructions": "Please answer each question as it pertains to your dizziness or unsteadiness problems. Consider your condition during the last month.",
    "estimatedTime": "5-10 minutes",
    "scoringType": "sum",
    "maxScore": 100,
    "totalItems": 25,
    "cutoff": 10,

    "domains": {
        "physical": {
            "name": "Physical",
            "items": [0, 3, 7, 10, 12, 16, 24],
            "maxScore": 28,
            "description": "Physical aspects of dizziness triggered by movements or positions"
        },
        "emotional": {
            "name": "Emotional",
            "items": [1, 8, 9, 14, 17, 19, 20, 21, 22],
            "maxScore": 36,
            "description": "Emotional consequences of dizziness"
        },
        "functional": {
            "name": "Functional",
            "items": [2, 4, 5, 6, 11, 13, 15, 18, 23],
            "maxScore": 36,
            "description": "Functional limitations in daily activities due to dizziness"
        }
    },

