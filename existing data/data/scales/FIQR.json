        }
    ],

    "interpretation": {
        "scoringMethod": "The FIQR uses weighted domain scoring: (1) Physical Function (Q1-9): sum raw scores and divide by 3 (max 30 points). (2) Overall Impact (Q10-11): sum raw scores directly (max 20 points). (3) Symptom Severity (Q12-21): sum raw scores and divide by 2 (max 50 points). Total FIQR = Function + Overall + Symptoms (range 0-100).",
        "domainScoring": {
            "function": "Sum of Q1-9 ÷ 3 = 0-30 points",
            "overall": "Sum of Q10-11 = 0-20 points",
            "symptoms": "Sum of Q12-21 ÷ 2 = 0-50 points"
        },
        "clinicalSignificance": "Higher scores indicate greater fibromyalgia impact. A change of approximately 14% from baseline is considered clinically meaningful. Scores >45 generally indicate substantial impairment."
    },

