{
    "id": "ALSFRS-R",
    "name": "ALS Functional Rating Scale - Revised",
    "shortName": "ALSFRS-R",
    "version": "1.0",
    "description": "A validated instrument for evaluating functional status and decline in patients with amyotrophic lateral sclerosis (ALS). Assesses bulbar, fine motor, gross motor, and respiratory function.",
    "category": "als",
    "recallPeriod": "Current functional status",
    "instructions": "Please rate the patient's current functional ability in each area. Score each item from 4 (normal function) to 0 (no function).",
    "estimatedTime": "5-10 minutes",
    "scoringType": "sum",
    "maxScore": 48,
    "totalItems": 12,
    "scoreDirection": "higher-is-better",

    "domains": {
        "bulbar": {
            "name": "Bulbar Function",
            "items": [0, 1, 2],
            "maxScore": 12,
            "description": "Speech, salivation, and swallowing"
        },
        "fine-motor": {
            "name": "Fine Motor Function",
            "items": [3, 4, 5],
            "maxScore": 12,
            "description": "Handwriting, cutting food, dressing and hygiene"
        },
        "gross-motor": {
            "name": "Gross Motor Function",
            "items": [6, 7, 8],
            "maxScore": 12,
            "description": "Turning in bed, walking, climbing stairs"
        },
        "respiratory": {
            "name": "Respiratory Function",
            "items": [9, 10, 11],
            "maxScore": 12,
            "description": "Dyspnea, orthopnea, respiratory insufficiency"
        }
    },

    "questions": [
        {
            "id": "ALSFRS-R_1",
            "number": 1,
            "question": "Speech",
            "domain": "bulbar",
            "type": "likert",
            "required": true,
            "options": [
                { "value": 4, "label": "Normal", "points": 4 },
                { "value": 3, "label": "Detectable speech disturbance", "points": 3 },
                { "value": 2, "label": "Intelligible with repeating", "points": 2 },
                { "value": 1, "label": "Speech combined with non-vocal communication", "points": 1 },
                { "value": 0, "label": "Loss of useful speech", "points": 0 }
            ]
        },
        {
            "id": "ALSFRS-R_2",
            "number": 2,
            "question": "Salivation",
            "domain": "bulbar",
            "type": "likert",
            "required": true,
            "options": [
                { "value": 4, "label": "Normal", "points": 4 },
                { "value": 3, "label": "Slight but definite excess of saliva in mouth; may have nighttime drooling", "points": 3 },
                { "value": 2, "label": "Moderately excessive saliva; may have minimal drooling", "points": 2 },
                { "value": 1, "label": "Marked excess of saliva with some drooling", "points": 1 },
                { "value": 0, "label": "Marked drooling; requires constant tissue or handkerchief", "points": 0 }
            ]
        },
        {
            "id": "ALSFRS-R_3",
            "number": 3,
            "question": "Swallowing",
            "domain": "bulbar",
            "type": "likert",
            "required": true,
            "options": [
                { "value": 4, "label": "Normal", "points": 4 },
                { "value": 3, "label": "Early eating problems—occasional choking", "points": 3 },
                { "value": 2, "label": "Dietary consistency changes", "points": 2 },
                { "value": 1, "label": "Needs supplemental tube feeding", "points": 1 },
                { "value": 0, "label": "NPO (exclusively parenteral or enteral feeding)", "points": 0 }
            ]
        },
        {
            "id": "ALSFRS-R_4",
            "number": 4,
            "question": "Handwriting",
            "domain": "fine-motor",
            "type": "likert",
            "required": true,
            "options": [
                { "value": 4, "label": "Normal", "points": 4 },
                { "value": 3, "label": "Slow or sloppy; all words are legible", "points": 3 },
                { "value": 2, "label": "Not all words are legible", "points": 2 },
                { "value": 1, "label": "Able to grip pen but unable to write", "points": 1 },
                { "value": 0, "label": "Unable to grip pen", "points": 0 }
            ]
        },
        {
            "id": "ALSFRS-R_5",
            "number": 5,
            "question": "Cutting food and handling utensils",
            "domain": "fine-motor",
            "type": "likert",
            "required": true,
            "options": [
                { "value": 4, "label": "Normal", "points": 4 },
                { "value": 3, "label": "Somewhat slow and clumsy, but no help needed", "points": 3 },
                { "value": 2, "label": "Can cut most foods, although clumsy and slow; some help needed", "points": 2 },
                { "value": 1, "label": "Food must be cut by someone, but can still feed slowly", "points": 1 },
                { "value": 0, "label": "Needs to be fed", "points": 0 }
            ]
        },
        {
            "id": "ALSFRS-R_6",
            "number": 6,
            "question": "Dressing and hygiene",
            "domain": "fine-motor",
            "type": "likert",
            "required": true,
            "options": [
                { "value": 4, "label": "Normal", "points": 4 },
                { "value": 3, "label": "Independent and complete self-care with effort or decreased efficiency", "points": 3 },
                { "value": 2, "label": "Intermittent assistance or substitute methods", "points": 2 },
                { "value": 1, "label": "Needs attendant for self-care", "points": 1 },
                { "value": 0, "label": "Total dependence", "points": 0 }
            ]
        },
        {
            "id": "ALSFRS-R_7",
            "number": 7,
            "question": "Turning in bed and adjusting bed clothes",
            "domain": "gross-motor",
            "type": "likert",
            "required": true,
            "options": [
                { "value": 4, "label": "Normal", "points": 4 },
                { "value": 3, "label": "Somewhat slow and clumsy, but no help needed", "points": 3 },
                { "value": 2, "label": "Can turn alone or adjust sheets, but with great difficulty", "points": 2 },
                { "value": 1, "label": "Can initiate, but not turn or adjust sheets alone", "points": 1 },
                { "value": 0, "label": "Helpless", "points": 0 }
            ]
        },
        {
            "id": "ALSFRS-R_8",
            "number": 8,
            "question": "Walking",
            "domain": "gross-motor",
            "type": "likert",
            "required": true,
            "options": [
                { "value": 4, "label": "Normal", "points": 4 },
                { "value": 3, "label": "Early ambulation difficulties", "points": 3 },
                { "value": 2, "label": "Walks with assistance", "points": 2 },
                { "value": 1, "label": "Non-ambulatory functional movement only", "points": 1 },
                { "value": 0, "label": "No purposeful leg movement", "points": 0 }
            ]
        },
        {
            "id": "ALSFRS-R_9",
            "number": 9,
            "question": "Climbing stairs",
            "domain": "gross-motor",
            "type": "likert",
            "required": true,
            "options": [
                { "value": 4, "label": "Normal", "points": 4 },
                { "value": 3, "label": "Slow", "points": 3 },
                { "value": 2, "label": "Mild unsteadiness or fatigue", "points": 2 },
                { "value": 1, "label": "Needs assistance", "points": 1 },
                { "value": 0, "label": "Cannot do", "points": 0 }
            ]
        },
        {
            "id": "ALSFRS-R_10",
            "number": 10,
            "question": "Dyspnea (shortness of breath)",
            "domain": "respiratory",
            "type": "likert",
            "required": true,
            "options": [
                { "value": 4, "label": "None", "points": 4 },
                { "value": 3, "label": "Occurs when walking", "points": 3 },
                { "value": 2, "label": "Occurs with one or more ADL: eating, bathing, dressing", "points": 2 },
                { "value": 1, "label": "Occurs at rest, difficulty breathing when sitting or lying", "points": 1 },
                { "value": 0, "label": "Significant difficulty, considering mechanical respiratory support", "points": 0 }
            ]
        },
        {
            "id": "ALSFRS-R_11",
            "number": 11,
            "question": "Orthopnea (difficulty breathing when lying down)",
            "domain": "respiratory",
            "type": "likert",
            "required": true,
            "options": [
                { "value": 4, "label": "None", "points": 4 },
                { "value": 3, "label": "Some difficulty sleeping at night due to shortness of breath; does not routinely use more than two pillows", "points": 3 },
                { "value": 2, "label": "Needs extra pillows in order to sleep (more than two)", "points": 2 },
                { "value": 1, "label": "Can only sleep sitting up", "points": 1 },
                { "value": 0, "label": "Unable to sleep", "points": 0 }
            ]
        },
        {
            "id": "ALSFRS-R_12",
            "number": 12,
            "question": "Respiratory insufficiency",
            "domain": "respiratory",
            "type": "likert",
            "required": true,
            "options": [
                { "value": 4, "label": "None", "points": 4 },
                { "value": 3, "label": "Intermittent use of BiPAP", "points": 3 },
                { "value": 2, "label": "Continuous use of BiPAP at night", "points": 2 },
                { "value": 1, "label": "Continuous use of BiPAP during night and day", "points": 1 },
                { "value": 0, "label": "Invasive mechanical ventilation by intubation or tracheostomy", "points": 0 }
            ]
        }
    ],

    "severityBands": [
        {
            "id": "normal",
            "label": "Normal/Minimal Impairment",
            "min": 40,
            "max": 48,
            "color": "#22c55e",
            "description": "Near-normal function across all domains."
        },
        {
            "id": "mild",
            "label": "Mild Impairment",
            "min": 30,
            "max": 39,
            "color": "#84cc16",
            "description": "Mild functional decline; largely independent."
        },
        {
            "id": "moderate",
            "label": "Moderate Impairment",
            "min": 20,
            "max": 29,
            "color": "#eab308",
            "description": "Moderate functional decline; some assistance needed."
        },
        {
            "id": "severe",
            "label": "Severe Impairment",
            "min": 10,
            "max": 19,
            "color": "#f97316",
            "description": "Severe functional decline; significant assistance required."
        },
        {
            "id": "very-severe",
            "label": "Very Severe Impairment",
            "min": 0,
            "max": 9,
            "color": "#ef4444",
            "description": "Near-total functional loss; dependent for most activities."
        }
    ],

    "interpretation": {
        "scoringMethod": "Sum of all 12 items. Each item scored 0-4 (4=normal, 0=unable). Total range: 0-48. Higher scores indicate better function.",
        "declineRate": "Average decline is approximately 1.1 points per month. A decline of 2-4 points is clinically meaningful.",
        "domainScores": "Bulbar (0-12), Fine Motor (0-12), Gross Motor (0-12), Respiratory (0-12)",
        "clinicalNotes": "The ALSFRS-R is validated for tracking disease progression in ALS. Respiratory items (10-12) were added to the original ALSFRS to better capture respiratory decline."
    },

    "references": [
        {
            "citation": "Cedarbaum JM, Stambler N, Malta E, et al. The ALSFRS-R: a revised ALS functional rating scale that incorporates assessments of respiratory function. J Neurol Sci. 1999;169(1-2):13-21.",
            "url": "https://doi.org/10.1016/S0022-510X(99)00210-5"
        }
    ],

    "metadata": {
        "createdAt": "2026-02-11",
        "updatedAt": "2026-02-11",
        "author": "Cedarbaum JM et al.",
        "license": "Public domain for clinical use"
    }
}
