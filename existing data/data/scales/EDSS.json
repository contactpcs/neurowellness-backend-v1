{
    "id": "EDSS",
    "name": "Expanded Disability Status Scale",
    "shortName": "EDSS",
    "version": "1.0",
    "description": "A clinician-rated scale for quantifying disability in multiple sclerosis and other neurological conditions.",
    "category": "disability",
    "recallPeriod": "Current neurological examination",
    "timeToComplete": "15-20 minutes",
    "scoringType": "clinician",
    "maxScore": 10,
    "isClinician": true,
    "administratorType": "neurologist",
    
    "instructions": "The EDSS quantifies disability in eight Functional Systems (FS). Score each Functional System first, then determine the overall EDSS score.",
    
    "questions": [
        {
            "index": 0,
            "label": "Pyramidal Functions (motor strength)",
            "question": "Rate the patient's pyramidal (motor) function - weakness or difficulty moving limbs.",
            "type": "single-choice",
            "section": "functional-systems",
            "required": true,
            "options": [
                { "value": 0, "label": "Normal" },
                { "value": 1, "label": "Abnormal signs without disability" },
                { "value": 2, "label": "Minimal disability" },
                { "value": 3, "label": "Mild to moderate paraparesis or hemiparesis" },
                { "value": 4, "label": "Marked paraparesis or hemiparesis" },
                { "value": 5, "label": "Paraplegia, hemiplegia, or marked quadriparesis" },
                { "value": 6, "label": "Quadriplegia" }
            ]
        },
        {
            "index": 1,
            "label": "Cerebellar Functions (coordination)",
            "question": "Rate the patient's cerebellar function - coordination and balance.",
            "type": "single-choice",
            "section": "functional-systems",
            "required": true,
            "options": [
                { "value": 0, "label": "Normal" },
                { "value": 1, "label": "Abnormal signs without disability" },
                { "value": 2, "label": "Mild ataxia" },
                { "value": 3, "label": "Moderate truncal or limb ataxia" },
                { "value": 4, "label": "Severe ataxia in all limbs" },
                { "value": 5, "label": "Unable to perform coordinated movements" }
            ]
        },
        {
            "index": 2,
            "label": "Brainstem Functions",
            "question": "Rate the patient's brainstem function - speech, swallowing, eye movements.",
            "type": "single-choice",
            "section": "functional-systems",
            "required": true,
            "options": [
                { "value": 0, "label": "Normal" },
                { "value": 1, "label": "Signs only" },
                { "value": 2, "label": "Moderate nystagmus or mild disability" },
                { "value": 3, "label": "Severe nystagmus or moderate cranial nerve disability" },
                { "value": 4, "label": "Marked dysarthria or marked disability" },
                { "value": 5, "label": "Inability to swallow or speak" }
            ]
        },
        {
            "index": 3,
            "label": "Sensory Functions",
            "question": "Rate the patient's sensory function - touch, pain, position sense, vibration.",
            "type": "single-choice",
            "section": "functional-systems",
            "required": true,
            "options": [
                { "value": 0, "label": "Normal" },
                { "value": 1, "label": "Vibration decrease only in 1-2 limbs" },
                { "value": 2, "label": "Mild decrease in touch/pain/position in 1-2 limbs" },
                { "value": 3, "label": "Moderate decrease in touch/pain/position in 1-2 limbs" },
                { "value": 4, "label": "Marked decrease in touch/pain in 1-2 limbs" },
                { "value": 5, "label": "Loss of sensation in 1-2 limbs" },
                { "value": 6, "label": "Sensation essentially lost below the head" }
            ]
        },
        {
            "index": 4,
            "label": "Bowel and Bladder Functions",
            "question": "Rate the patient's bowel and bladder function.",
            "type": "single-choice",
            "section": "functional-systems",
            "required": true,
            "options": [
                { "value": 0, "label": "Normal" },
                { "value": 1, "label": "Mild urinary hesitancy, urgency, or retention" },
                { "value": 2, "label": "Moderate hesitancy/urgency/retention, rare incontinence" },
                { "value": 3, "label": "Frequent urinary incontinence" },
                { "value": 4, "label": "Almost constant catheterization needed" },
                { "value": 5, "label": "Loss of bladder function" },
                { "value": 6, "label": "Loss of bowel and bladder function" }
            ]
        },
        {
            "index": 5,
            "label": "Visual Functions",
            "question": "Rate the patient's visual function - vision and visual acuity.",
            "type": "single-choice",
            "section": "functional-systems",
            "required": true,
            "options": [
                { "value": 0, "label": "Normal" },
                { "value": 1, "label": "Scotoma with acuity better than 20/30" },
                { "value": 2, "label": "Worse eye acuity 20/30-20/59" },
                { "value": 3, "label": "Worse eye acuity 20/60-20/99" },
                { "value": 4, "label": "Worse eye acuity 20/100-20/200" },
                { "value": 5, "label": "Worse eye acuity less than 20/200" },
                { "value": 6, "label": "Grade 5 plus better eye 20/60 or less" }
            ]
        },
        {
            "index": 6,
            "label": "Cerebral (Mental) Functions",
            "question": "Rate the patient's cerebral function - mood, cognition, fatigue.",
            "type": "single-choice",
            "section": "functional-systems",
            "required": true,
            "options": [
                { "value": 0, "label": "Normal" },
                { "value": 1, "label": "Mood alteration only" },
                { "value": 2, "label": "Mild decrease in mentation" },
                { "value": 3, "label": "Moderate decrease in mentation" },
                { "value": 4, "label": "Marked decrease in mentation" },
                { "value": 5, "label": "Dementia or chronic brain syndrome - severe" }
            ]
        },
        {
            "index": 7,
            "label": "Other Functions",
            "question": "Any other neurological findings attributable to MS?",
            "type": "single-choice",
            "section": "functional-systems",
            "required": true,
            "options": [
                { "value": 0, "label": "None" },
                { "value": 1, "label": "Any other neurological finding attributed to MS" }
            ]
        },
        {
            "index": 8,
            "label": "Ambulation Assessment",
            "question": "Assess the patient's walking ability and maximum distance without aid or rest.",
            "type": "single-choice",
            "section": "ambulation",
            "required": true,
            "options": [
                { "value": 0, "label": "Fully ambulatory - unlimited walking distance" },
                { "value": 1, "label": "Can walk at least 500 meters without aid" },
                { "value": 2, "label": "Can walk 300-499 meters without aid" },
                { "value": 3, "label": "Can walk 200-299 meters without aid" },
                { "value": 4, "label": "Can walk 100-199 meters without aid" },
                { "value": 5, "label": "Requires unilateral support to walk 100m" },
                { "value": 6, "label": "Requires bilateral support to walk 20m" },
                { "value": 7, "label": "Unable to walk 20 meters; wheelchair bound" },
                { "value": 8, "label": "Restricted to bed or chair" }
            ]
        },
        {
            "index": 9,
            "label": "Overall EDSS Score",
            "question": "Based on the Functional System scores and ambulation, select the overall EDSS score.",
            "type": "single-choice",
            "section": "edss-score",
            "required": true,
            "isOverallScore": true,
            "options": [
                { "value": 0.0, "label": "0.0 - Normal neurological exam" },
                { "value": 1.0, "label": "1.0 - No disability, minimal signs in one FS" },
                { "value": 1.5, "label": "1.5 - No disability, minimal signs in multiple FS" },
                { "value": 2.0, "label": "2.0 - Minimal disability in one FS" },
                { "value": 2.5, "label": "2.5 - Minimal disability in two FS" },
                { "value": 3.0, "label": "3.0 - Moderate disability in one FS, fully ambulatory" },
                { "value": 3.5, "label": "3.5 - Fully ambulatory, moderate disability" },
                { "value": 4.0, "label": "4.0 - Fully ambulatory without aid, can walk 500m" },
                { "value": 4.5, "label": "4.5 - Fully ambulatory without aid, can walk 300m" },
                { "value": 5.0, "label": "5.0 - Ambulatory without aid for about 200m" },
                { "value": 5.5, "label": "5.5 - Ambulatory without aid for about 100m" },
                { "value": 6.0, "label": "6.0 - Unilateral assistance required to walk 100m" },
                { "value": 6.5, "label": "6.5 - Bilateral assistance required to walk 20m" },
                { "value": 7.0, "label": "7.0 - Unable to walk beyond 5m, wheelchair bound" },
                { "value": 7.5, "label": "7.5 - Unable to take more than a few steps" },
                { "value": 8.0, "label": "8.0 - Restricted to bed/chair, retains self-care" },
                { "value": 8.5, "label": "8.5 - Restricted to bed much of day" },
                { "value": 9.0, "label": "9.0 - Helpless bed patient, can communicate" },
                { "value": 9.5, "label": "9.5 - Totally helpless bed patient" },
                { "value": 10.0, "label": "10.0 - Death due to MS" }
            ]
        }
    ],
    
    "severityBands": [
        { "min": 0, "max": 1.5, "level": "normal", "label": "No Disability", "color": "#4CAF50" },
        { "min": 2.0, "max": 2.5, "level": "minimal", "label": "Minimal Disability", "color": "#8BC34A" },
        { "min": 3.0, "max": 4.5, "level": "moderate", "label": "Moderate Disability", "color": "#FFC107" },
        { "min": 5.0, "max": 5.5, "level": "significant", "label": "Significant Disability", "color": "#FF9800" },
        { "min": 6.0, "max": 6.5, "level": "severe", "label": "Severe - Requires Walking Aid", "color": "#FF5722" },
        { "min": 7.0, "max": 7.5, "level": "wheelchair", "label": "Wheelchair Bound", "color": "#E91E63" },
        { "min": 8.0, "max": 9.5, "level": "bed-bound", "label": "Bed Bound", "color": "#9C27B0" },
        { "min": 10.0, "max": 10.0, "level": "death", "label": "Death due to MS", "color": "#000000" }
    ],
    
    "interpretation": {
        "clinicalNotes": "EDSS scores 0-4.5 are determined primarily by FS scores. Scores 4.0-7.5 are determined primarily by ambulation ability.",
        "keyThresholds": [
            { "score": 3.0, "significance": "Moderate disability threshold" },
            { "score": 4.0, "significance": "Significant disability but fully ambulatory" },
            { "score": 6.0, "significance": "Requires walking aid" },
            { "score": 7.0, "significance": "Wheelchair-dependent" }
        ]
    }
}
