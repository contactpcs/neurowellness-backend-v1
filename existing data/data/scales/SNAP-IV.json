{
    "id": "SNAP-IV",
    "name": "SNAP-IV 26-Item Teacher and Parent Rating Scale",
    "shortName": "SNAP-IV-26",
    "version": "1.0",
    "description": "An abbreviated version of the Swanson, Nolan, and Pelham (SNAP) Questionnaire used to assess ADHD and Oppositional Defiant Disorder symptoms based on DSM-IV criteria. Includes subscales for Inattention, Hyperactivity/Impulsivity, and Opposition/Defiance.",
    "category": "adhd",
    "recallPeriod": "Current behavior",
    "instructions": "For each item, check the column which best describes this child/adolescent. Rate how often each behavior occurs.",
    "estimatedTime": "10 minutes",
    "scoringType": "sum-subscales",
    "maxScore": 78,
    "totalItems": 26,
    "administrationType": "informant-rated",
    "informants": ["teacher", "parent"],

