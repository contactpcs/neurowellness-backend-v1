    "interpretation": {
        "scoringMethod": "Score each item 0-3 and sum within each subscale. Scores can also be averaged by dividing subscale total by number of items.",
        "subscaleCutoffs": {
            "inattention": "<13 not significant, 13-17 mild, 18-22 moderate, 23-27 severe",
            "hyperactivityImpulsivity": "<13 not significant, 13-17 mild, 18-22 moderate, 23-27 severe",
            "oppositionDefiance": "<8 not significant, 8-13 mild, 14-18 moderate, 19-24 severe"
        },
        "targetScores": {
            "inattention": "<13/27",
            "hyperactivityImpulsivity": "<13/27",
            "oppositionDefiance": "<8/24"
        },
        "averageScoring": "Average rating can be calculated by dividing subscale total by number of items. Compare with published cut-off scores.",
        "clinicalNote": "Based on DSM-IV criteria for ADHD and ODD. ODD subscale included because ODD is often present in children with ADHD."
    },

